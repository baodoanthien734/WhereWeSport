# Root level .gitignore for WhereWeSport project

# Environment variables
.env
.env.local
.env.*.local

# Node modules
node_modules/

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# Build outputs
dist/
build/
*.tgz

# Temporary files
tmp/
temp/
*.tmp

# Database
*.db
*.sqlite
*.sqlite3

# SSL certificates
*.pem
*.key
*.cert
*.crt

# Backup files
*.bak
*.backup
*.backup.*

# Sensitive data
credentials.json
secrets.json
config/secrets/
